{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Manual Global IB Targets",
  "description": "User-curated per-firm global IB target prices. Per ticker, a list of firm entries.",
  "type": "object",
  "patternProperties": {
    "^[0-9]{6}$": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["firm", "target_price", "currency", "report_date", "source"],
        "properties": {
          "firm": {
            "type": "string",
            "description": "Canonical English IB name (must be in IB_NAME_ALIASES values)",
            "enum": [
              "JPMorgan", "Goldman Sachs", "Morgan Stanley", "BofA",
              "Citi", "UBS", "Barclays", "HSBC", "Macquarie",
              "CLSA", "Nomura", "Daiwa", "Mizuho", "Deutsche Bank"
            ]
          },
          "target_price": {
            "type": "number",
            "exclusiveMinimum": 0,
            "description": "Target price in the specified currency"
          },
          "currency": {
            "type": "string",
            "enum": ["KRW", "USD"]
          },
          "report_date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "description": "ISO date of the analyst report"
          },
          "source": {
            "type": "string",
            "description": "Where the user got this (e.g., 'manual_pdf', 'broker_email')"
          },
          "rating": {
            "type": "string",
            "description": "e.g., Overweight, Buy, Neutral"
          },
          "user_note": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
