{
    "env": {
        "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
    },
    "permissions":  {
                        "defaultMode":  "bypassPermissions",
                        "allow":  [
                                      "Bash(*)",
                                      "Write(*)",
                                      "Read(*)"
                                  ],
                        "deny":  [
                                     "Bash(git push --force *)",
                                     "Bash(git push -f *)",
                                     "Bash(git push --force-with-lease *)",
                                     "Bash(gh secret set *)",
                                     "Bash(rm -rf *)",
                                     "Bash(rm -rf /*)",
                                     "Write(.env)",
                                     "Write(*/.env)"
                                 ]
                    },
    "hooks": {
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "python \"C:\\Users\\JY Hwang\\Desktop\\AI Projects\\AI Analyzer\\.claude\\hooks\\stop_hook.py\""
                    }
                ]
            }
        ],
        "SubagentStop": [
            {
                "matcher": "^(data|analysis|evaluator|validation|decision|stock|sector|news|narrative|ui|report|audit|meta-audit)-agent$",
                "hooks": [
                    {
                        "type": "command",
                        "command": "python",
                        "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/tf_schema_check.py"],
                        "timeout": 15
                    }
                ]
            },
            {
                "matcher": ".*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "python",
                        "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/agent_activity_log.py"],
                        "timeout": 5
                    }
                ]
            }
        ],
        "PostToolBatch": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "python",
                        "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/tf_aggregate.py"],
                        "timeout": 30
                    }
                ]
            }
        ],
        "SessionEnd": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "python",
                        "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/lesson_save.py"],
                        "timeout": 10
                    }
                ]
            }
        ]
    }
}
